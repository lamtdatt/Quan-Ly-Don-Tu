        function toggleLanguage() {
            let currentLang = localStorage.getItem('dangcapne_lang') || 'vi';
            let newLang = currentLang === 'vi' ? 'en' : 'vi';
            localStorage.setItem('dangcapne_lang', newLang);
            applyLanguage(newLang);
            window.dispatchEvent(new Event('languageChanged'));
        }

        function applyLanguage(lang) {
            document.getElementById('langDisplay').innerText = lang.toUpperCase();
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if(dict[lang] && dict[lang][key]) {
                    if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                        el.setAttribute('placeholder', dict[lang][key]);
                    } else {
                        const icon = el.querySelector('i');
                        if (icon) {
                            el.innerHTML = '';
                            el.appendChild(icon);
                            el.append(' ' + dict[lang][key]);
                        } else {
                            el.innerText = dict[lang][key];
                        }
                    }
                }
            });
            // Global hook — pages can override window.onPageLanguageChange(lang) to react
            if (typeof window.onPageLanguageChange === 'function') {
                window.onPageLanguageChange(lang);
            }
        }

        // Initialize Theme & Lang on load
        document.addEventListener('DOMContentLoaded', function() {
            document.documentElement.setAttribute('data-theme', 'light');
            
            const savedLang = localStorage.getItem('dangcapne_lang') || 'vi';
            applyLanguage(savedLang);
        });

        document.addEventListener('click', function (e) {
            const dd = document.getElementById('notifDropdown');
            const bell = document.getElementById('notifBell');
            if (dd && bell && !dd.contains(e.target) && !bell.contains(e.target)) {
                dd.classList.remove('show');
            }
        });

        async function loadNotifications() {
            try {
                const res = await fetch('/Notifications/GetRecent');
                const data = await res.json();
                const list = document.getElementById('notifList');
                if (!list) return;
                list.innerHTML = data.notifications.map(n => `
                    <a href="${n.actionUrl || '#'}" class="notif-item ${n.isRead ? '' : 'unread'}" onclick="markRead(${n.id})">
                        <div class="notif-title">${n.title}</div>
                        <div class="notif-msg">${n.message}</div>
                        <div class="notif-time">${n.createdAt}</div>
                    </a>
                `).join('') || '<div class="empty-state" style="padding:32px"><i class="bi bi-bell-slash"></i><p data-i18n="EmptyNotif">' + (dict[localStorage.getItem('dangcapne_lang') || 'vi']?.EmptyNotif || 'Không có thông báo') + '</p></div>';
                updateBadge(data.unreadCount);
            } catch (e) { }
        }

        function updateBadge(count) {
            const badge = document.getElementById('notifBadge');
            const sideCount = document.getElementById('sidebarNotifCount');
            if (badge) {
                badge.style.display = count > 0 ? 'inline-flex' : 'none';
                badge.textContent = count;
            }
            if (sideCount) {
                sideCount.style.display = count > 0 ? 'inline-flex' : 'none';
                sideCount.textContent = count;
            }
        }

        async function markRead(id) {
            try {
                await fetch(`/Notifications/MarkRead/${id}`, { method: 'POST' });
                loadNotifications();
            } catch (e) { }
        }

        async function markAllRead() {
            try {
                await fetch('/Notifications/MarkAllRead', { method: 'POST' });
                loadNotifications();
            } catch (e) { }
        }
    </script>

    <!-- Global AI Chatbox -->
    <div class="ai-chat-widget" id="aiChatWidget">
        <button class="ai-chat-btn" id="aiChatBtn" title="Trợ lý AI (Kéo để di chuyển)">
            <i class="bi bi-robot"></i>
        </button>
        <div class="ai-chat-panel" id="aiChatPanel" style="display: none;">
            <div class="ai-chat-header">
                <div>
                    <div class="ai-chat-title"><i class="bi bi-stars"></i> <span data-i18n="LayoutAITitle">Trợ lý DANGCAPNE</span></div>
                    <div class="ai-chat-subtitle" data-i18n="LayoutAISub">Luôn sẵn sàng hỗ trợ bạn</div>
                </div>
                <div style="display:flex; gap: 8px;">
                    <button class="ai-close-btn" onclick="clearAIChat()"><i class="bi bi-trash"></i></button>
                    <button class="ai-close-btn" onclick="toggleAIChat()"><i class="bi bi-x"></i></button>
                </div>
            </div>
            <div class="ai-chat-messages" id="aiChatMessages">
                <div class="chat-msg ai-msg" data-i18n="LayoutAIGreet">Xin chào! Em là trợ lý ảo của hệ thống DANGCAPNE. Anh/chị cần em giúp gì ạ?</div>
            </div>
            <div class="ai-chat-input">
                <input type="text" id="aiChatInput" placeholder="Nhắn tin cho trợ lý ảo..." data-i18n="LayoutAIPlaceholder" onkeypress="handleAIChatEnter(event)" autocomplete="off" />
                <button onclick="sendAIChat()"><i class="bi bi-send-fill"></i></button>
            </div>
        </div>
    </div>

    <script>
        // --- Drag Chatbox Logic ---
        const widget = document.getElementById('aiChatWidget');
        const chatBtn = document.getElementById('aiChatBtn');
        let isDraggingChat = false;
        let dragStartX, dragStartY;

        chatBtn.addEventListener('mousedown', startDrag);
        chatBtn.addEventListener('touchstart', startDrag, { passive: true });

        document.addEventListener('mousemove', doDrag);
        document.addEventListener('touchmove', doDrag, { passive: false });

        document.addEventListener('mouseup', endDrag);
        document.addEventListener('touchend', endDrag);

        function startDrag(e) {
            isDraggingChat = false;
            let clientX = e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
            let clientY = e.type.includes('mouse') ? e.clientY : e.touches[0].clientY;
            
            dragStartX = clientX;
            dragStartY = clientY;
            
            let rect = widget.getBoundingClientRect();
            widget.style.bottom = 'auto';
            widget.style.right = 'auto';
            widget.style.left = rect.left + 'px';
            widget.style.top = rect.top + 'px';
            
            chatBtn.style.cursor = 'grabbing';
        }

        function doDrag(e) {
            if (dragStartX === undefined) return;
            
            let clientX = e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
            let clientY = e.type.includes('mouse') ? e.clientY : e.touches[0].clientY;
            
            let dx = clientX - dragStartX;
            let dy = clientY - dragStartY;
            
            if (Math.abs(dx) > 3 || Math.abs(dy) > 3) {
                isDraggingChat = true;
                if(e.type === 'touchmove') e.preventDefault();
                
                let rect = widget.getBoundingClientRect();
                let newLeft = rect.left + dx;
                let newTop = rect.top + dy;
                
                // Keep widget within screen bounds
                newLeft = Math.max(0, Math.min(newLeft, window.innerWidth - rect.width));
                newTop = Math.max(0, Math.min(newTop, window.innerHeight - rect.height));

                widget.style.left = newLeft + 'px';
                widget.style.top = newTop + 'px';
                
                dragStartX = clientX;
                dragStartY = clientY;
            }
        }

        function endDrag(e) {
            if (dragStartX !== undefined) {
                if (!isDraggingChat) {
                    toggleAIChat();
                }
                dragStartX = undefined;
                dragStartY = undefined;
                chatBtn.style.cursor = 'grab';
            }
        }

        // --- Chat Logic ---
        const currentUserId = '@Context.Session.GetInt32("UserId")' || 'guest';
        const chatStorageKey = 'dangcapne_chat_history_' + currentUserId;
        let chatHistory = JSON.parse(localStorage.getItem(chatStorageKey)) || [];
        let isChatInitialLoaded = false;

        function toggleAIChat() {
            const panel = document.getElementById('aiChatPanel');
            const btn = document.getElementById('aiChatBtn');
            const currentLang = localStorage.getItem('dangcapne_lang') || 'vi';

            // Sync titles dynamically because titles aren't auto-checked by applyLanguage easily
            btn.title = dict[currentLang]?.LayoutAITooltip || "Trợ lý AI (Kéo để di chuyển)";

            if (panel.style.display === 'none') {
                panel.style.display = 'flex';
                btn.classList.add('active');
                
                if (!isChatInitialLoaded) {
                    renderChatHistory();
                    isChatInitialLoaded = true;
                } else {
                    // Refresh translations inside dynamically loaded UI elements
                    applyLanguage(currentLang);
                }
                
                const messagesDiv = document.getElementById('aiChatMessages');
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
                document.getElementById('aiChatInput').focus();
            } else {
                panel.style.display = 'none';
                btn.classList.remove('active');
            }
        }

        function renderChatHistory() {
            const messagesDiv = document.getElementById('aiChatMessages');
            const currentLang = localStorage.getItem('dangcapne_lang') || 'vi';
            const greetMsg = dict[currentLang]?.LayoutAIGreet || "Xin chào! Em là trợ lý ảo của hệ thống DANGCAPNE. Anh/chị cần em giúp gì ạ?";
            messagesDiv.innerHTML = `<div class="chat-msg ai-msg" data-i18n="LayoutAIGreet">${greetMsg}</div>`;
            
            chatHistory.forEach(msg => {
                let formattedText = msg.text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br/>');
                if (msg.role === 'user') {
                    messagesDiv.innerHTML += `<div class="chat-msg user-msg">${formattedText}</div>`;
                } else {
                    messagesDiv.innerHTML += `<div class="chat-msg ai-msg">${formattedText}</div>`;
                }
            });
            applyLanguage(currentLang);
        }

        function clearAIChat() {
            const currentLang = localStorage.getItem('dangcapne_lang') || 'vi';
            const confirmMsg = dict[currentLang]?.LayoutAIConfirmClear || "Bạn có chắc muốn xóa lịch sử trò chuyện này?";
            if (confirm(confirmMsg)) {
                chatHistory = [];
                localStorage.removeItem(chatStorageKey);
                renderChatHistory();
            }
        }

        async function sendAIChat() {
            const input = document.getElementById('aiChatInput');
            const messageText = input.value.trim();
            if (!messageText) return;

            const messagesDiv = document.getElementById('aiChatMessages');
            const currentLang = localStorage.getItem('dangcapne_lang') || 'vi';
            
            // Add user message to UI
            messagesDiv.innerHTML += `<div class="chat-msg user-msg">${escapeHtml(messageText)}</div>`;
            input.value = '';
            messagesDiv.scrollTop = messagesDiv.scrollHeight;

            // Push to history
            chatHistory.push({ role: 'user', text: messageText });
            localStorage.setItem(chatStorageKey, JSON.stringify(chatHistory));

            // Add typing indicator
            const typingId = 'typing-' + Date.now();
            const typingMsg = dict[currentLang]?.LayoutAITyping || "Đang suy nghĩ...";
            messagesDiv.innerHTML += `<div class="chat-msg ai-msg typing" id="${typingId}" data-i18n="LayoutAITyping">${typingMsg}</div>`;
            messagesDiv.scrollTop = messagesDiv.scrollHeight;

            try {
                const response = await fetch('/Requests/Chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ history: chatHistory })
                });

                document.getElementById(typingId)?.remove();

                if (response.ok) {
                    const data = await response.json();
                    let aiText = data.text;
                    
                    // Push to history
                    chatHistory.push({ role: 'ai', text: aiText });
                    localStorage.setItem(chatStorageKey, JSON.stringify(chatHistory));

                    // Format basic markdown
                    let formattedAiText = aiText.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br/>');
                    messagesDiv.innerHTML += `<div class="chat-msg ai-msg">${formattedAiText}</div>`;
                } else {
                    const errMsg = dict[currentLang]?.LayoutAIErrorConn || "Xin lỗi, đã xảy ra lỗi kết nối.";
                    messagesDiv.innerHTML += `<div class="chat-msg ai-msg error" data-i18n="LayoutAIErrorConn">${errMsg}</div>`;
                    chatHistory.pop(); // remove user msg if failed
                }
            } catch (e) {
                document.getElementById(typingId)?.remove();
                const srvMsg = dict[currentLang]?.LayoutAINoServer || "Không thể kết nối với máy chủ AI.";
                messagesDiv.innerHTML += `<div class="chat-msg ai-msg error" data-i18n="LayoutAINoServer">${srvMsg}</div>`;
                chatHistory.pop(); // remove user msg if failed
            }
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function handleAIChatEnter(e) {
            if (e.key === 'Enter') sendAIChat();
        }

        function escapeHtml(unsafe) {
            return unsafe
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
        }
    </script>
