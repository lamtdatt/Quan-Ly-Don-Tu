@model DANGCAPNE.ViewModels.ModulesIndexViewModel
@{
    ViewData["Title"] = ViewData["Title"] ?? "Phân hệ";
}

<div class="page-content">
    <div class="glass-card">
        <div class="card-header">
            <h3><i class="bi bi-folder-fill text-primary"></i> @ViewData["Title"]</h3>
        </div>
        <div class="card-body">
            <div class="grid-3">
                @foreach (var m in Model.Modules)
                {
                    <a href="@Url.Action("List", "Modules", new { key = m.Key })" class="module-card">
                        <div class="module-title">@m.Title</div>
                        <div class="module-desc">@m.Description</div>
                        <div class="module-cta">Quản lý</div>
                    </a>
                }
                @if (!Model.Modules.Any())
                {
                    <div class="empty-state" style="grid-column:1/-1">
                        <i class="bi bi-shield-lock"></i>
                        <p>Bạn không có quyền truy cập phân hệ nào.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
